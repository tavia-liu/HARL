{
    "main_args": {
        "algo": "happo",
        "env": "maniskill",
        "exp_name": "MultiPushCube_happo_fixed",
        "load_config": ""
    },
    "algo_args": {
        "seed": {
            "seed_specify": true,
            "seed": 0
        },
        "device": {
            "cuda": true,
            "cuda_deterministic": true,
            "torch_threads": 4
        },
        "train": {
            "n_rollout_threads": 1024,
            "num_env_steps": 5000000,
            "episode_length": 50,
            "log_interval": 5,
            "eval_interval": 10,
            "use_eval": true,
            "n_eval_rollout_threads": 64,
            "model_dir": null,
            "use_linear_lr_decay": false,
            "use_proper_time_limits": true,
            "use_valuenorm": true
        },
        "eval": {
            "n_eval_rollout_threads": 64,
            "eval_episodes": 20,
            "use_eval": true
        },
        "model": {
            "hidden_sizes": [256, 256, 256],
            "activation_func": "tanh",
            "use_feature_normalization": true,
            "initialization_method": "orthogonal_",
            "gain": 0.01,
            "use_naive_recurrent_policy": false,
            "use_recurrent_policy": false,
            "recurrent_n": 1,
            "data_chunk_length": 10,
            "lr": 0.0003,
            "critic_lr": 0.0003,
            "opti_eps": 1e-05,
            "weight_decay": 0,
            "std_x_coef": 1,
            "std_y_coef": 0.5
        },
        "algo": {
            "ppo_epoch": 4,
            "critic_epoch": 4,
            "use_clipped_value_loss": false,
            "clip_param": 0.2,
            "actor_num_mini_batch": 32,
            "critic_num_mini_batch": 32,
            "entropy_coef": 0.0,
            "value_loss_coef": 0.5,
            "use_max_grad_norm": true,
            "max_grad_norm": 0.5,
            "use_gae": true,
            "gamma": 0.8,
            "gae_lambda": 0.9,
            "use_huber_loss": false,
            "use_policy_active_masks": true,
            "huber_delta": 10.0,
            "action_aggregation": "prod",
            "share_param": false,
            "fixed_order": true
        },
        "render": {
            "use_render": false,
            "render_episodes": 10
        },
        "logger": {
            "log_dir": "./results"
        }
    },
    "env_args": {
        "task": "MultiPushCube-v1",
        "n_threads": 1024,
        "proprio_per_agent": 18,
        "extra_per_agent": 18,
        "episode_length": 50
    }
}
